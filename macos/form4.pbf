Procedure Window_0_Events(event)
  Select event
    Case #PB_Event_CloseWindow
      ProcedureReturn #False

    Case #PB_Event_Menu
      Select EventMenu()
      EndSelect

    Case #PB_Event_Gadget
      Select EventGadget()
        Case Button_0
          Do_Exit(EventType())          
        Case Button_1
          Do_Load(EventType())          
      EndSelect
  EndSelect
  ProcedureReturn #True
EndProcedure

