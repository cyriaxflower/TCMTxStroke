Procedure OpenWindow_0(x = 300, y = 100, width = 880, height = 730)
  Window_0 = OpenWindow(#PB_Any, x, y, width, height, "", #PB_Window_SystemMenu | #PB_Window_MinimizeGadget | #PB_Window_MaximizeGadget | #PB_Window_SizeGadget)
  Button_0 = ButtonGadget(#PB_Any, 40, 110, 570, 60, "請按我開啟類神經網路儲存檔案 (*.BIN)")
  SetGadgetFont(Button_0, FontID(#Font_Window_0_0))
  Button_1 = ButtonGadget(#PB_Any, 690, 120, 140, 60, "Exit")
  SetGadgetFont(Button_1, FontID(#Font_Window_0_0))
  Editor_0 = EditorGadget(#PB_Any, 40, 230, 800, 480)
  SetGadgetFont(Editor_0, FontID(#Font_Window_0_1))
  Text_0 = TextGadget(#PB_Any, 90, 10, 600, 40, " 類神經網路測試驗證程式 2025-Oct")
  SetGadgetColor(Text_0, #PB_Gadget_FrontColor,RGB(255,0,128))
  SetGadgetFont(Text_0, FontID(#Font_Window_0_2))
  Option_0 = OptionGadget(#PB_Any, 40, 50, 550, 50, "搜尋相關類神經網路存檔並全部驗證")
  SetGadgetFont(Option_0, FontID(#Font_Window_0_3))
  Checkbox_0 = CheckBoxGadget(#PB_Any, 40, 170, 220, 50, "驗證六大證型")
  SetGadgetFont(Checkbox_0, FontID(#Font_Window_0_4))
  Checkbox_1 = CheckBoxGadget(#PB_Any, 300, 170, 280, 50, "驗證其他中醫證型")
  SetGadgetFont(Checkbox_1, FontID(#Font_Window_0_4))
