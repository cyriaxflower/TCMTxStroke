  SetGadgetFont(Checkbox_2, FontID(#Font_Window_0_4))
  Button_2 = ButtonGadget(#PB_Any, 690, 50, 140, 60, "開始驗證")
  SetGadgetFont(Button_2, FontID(#Font_Window_0_4))
EndProcedure

Procedure Window_0_Events(event)
  Select event
    Case #PB_Event_CloseWindow
      ProcedureReturn #False

    Case #PB_Event_Menu
      Select EventMenu()
      EndSelect

    Case #PB_Event_Gadget
      Select EventGadget()
      EndSelect
  EndSelect
  ProcedureReturn #True
EndProcedure

