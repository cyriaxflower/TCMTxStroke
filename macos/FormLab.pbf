Global Window_2

Global Text_0, ListView_1

Enumeration FormFont
  #Font_Window_2_0
  #Font_Window_2_1
EndEnumeration

LoadFont(#Font_Window_2_0,"標楷體", 28)
LoadFont(#Font_Window_2_1,"標楷體", 18)


Procedure OpenWindow_2(x = 0, y = 0, width = 790, height = 430)
  Window_2 = OpenWindow(#PB_Any, x, y, width, height, "其他檢驗數據勾選選單", #PB_Window_SystemMenu | #PB_Window_MinimizeGadget | #PB_Window_MaximizeGadget | #PB_Window_SizeGadget | #PB_Window_WindowCentered | #PB_Window_SystemMenu | #PB_Window_MinimizeGadget | #PB_Window_MaximizeGadget | #PB_Window_SizeGadget | #PB_Window_WindowCentered)
  Text_0 = TextGadget(#PB_Any, 20, 20, 530, 50, "其他檢驗數據")
  SetGadgetFont(Text_0, FontID(#Font_Window_2_0))
  ListView_1 = ListViewGadget(#PB_Any, 30, 80, 740, 340, #PB_ListView_ClickSelect)
  SetGadgetFont(ListView_1, FontID(#Font_Window_2_1))
EndProcedure

Procedure Window_2_Events(event)
  Select event
    Case #PB_Event_CloseWindow
      ProcedureReturn #False

    Case #PB_Event_Menu
      Select EventMenu()
      EndSelect

    Case #PB_Event_Gadget
      Select EventGadget()
      EndSelect
  EndSelect
  ProcedureReturn #True
EndProcedure

