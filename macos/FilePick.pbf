Global Window_1

Global ListView_0, ListView_1, Button_4, Button_5, Button_6, Button_7, Button_8, Button_9, Text_4, Text_5, Text_6, Button_10, Text_7

Enumeration FormFont
  #Font_Window_1_0
  #Font_Window_1_1
  #Font_Window_1_2
EndEnumeration

LoadFont(#Font_Window_1_0,"標楷體", 18)
LoadFont(#Font_Window_1_1,"標楷體", 16)
LoadFont(#Font_Window_1_2,"標楷體", 20)


Procedure OpenWindow_1(x = 400, y = 200, width = 870, height = 550)
  Window_1 = OpenWindow(#PB_Any, x, y, width, height, "點選檔案後, 按下移動的按鈕, 最後按下完成按鈕", #PB_Window_SystemMenu)
  ListView_0 = ListViewGadget(#PB_Any, 40, 110, 240, 410)
  SetGadgetFont(ListView_0, FontID(#Font_Window_1_0))
  ListView_1 = ListViewGadget(#PB_Any, 480, 110, 240, 410)
  SetGadgetFont(ListView_1, FontID(#Font_Window_1_0))
  Button_4 = ButtonGadget(#PB_Any, 300, 110, 160, 50, "移動向右→")
  SetGadgetFont(Button_4, FontID(#Font_Window_1_1))
  Button_5 = ButtonGadget(#PB_Any, 300, 180, 160, 50, "←移動向左")
  SetGadgetFont(Button_5, FontID(#Font_Window_1_1))
  Button_6 = ButtonGadget(#PB_Any, 300, 250, 160, 50, "全部移動到右邊")
  SetGadgetFont(Button_6, FontID(#Font_Window_1_1))
  Button_7 = ButtonGadget(#PB_Any, 300, 320, 160, 50, "全部移動到左邊")
  SetGadgetFont(Button_7, FontID(#Font_Window_1_1))
  Button_8 = ButtonGadget(#PB_Any, 300, 390, 160, 50, "完  成")
  SetGadgetFont(Button_8, FontID(#Font_Window_1_0))
  Button_9 = ButtonGadget(#PB_Any, 300, 460, 160, 50, "放  棄")
  SetGadgetFont(Button_9, FontID(#Font_Window_1_0))
  Text_4 = TextGadget(#PB_Any, 40, 80, 240, 30, "下列為需要驗證的檔案")
  SetGadgetFont(Text_4, FontID(#Font_Window_1_1))
  Text_5 = TextGadget(#PB_Any, 480, 80, 250, 30, "下列為不需要驗證的檔案")
  SetGadgetFont(Text_5, FontID(#Font_Window_1_1))
  Text_6 = TextGadget(#PB_Any, 20, 20, 830, 30, "請挑選想要驗證的神經網路檔案 (左側擺需要驗證的檔案, 右側放不需要驗證的檔案)")
  SetGadgetFont(Text_6, FontID(#Font_Window_1_1))
  Button_10 = ButtonGadget(#PB_Any, 290, 50, 180, 50, "切換類型")
  SetGadgetFont(Button_10, FontID(#Font_Window_1_2))
  Text_7 = TextGadget(#PB_Any, 480, 50, 320, 25, "目前為六大證型")
  SetGadgetColor(Text_7, #PB_Gadget_FrontColor,RGB(255,0,0))
  SetGadgetFont(Text_7, FontID(#Font_Window_1_0))
EndProcedure

Procedure Window_1_Events(event)
  Select event
    Case #PB_Event_CloseWindow
      ProcedureReturn #False

    Case #PB_Event_Menu
      Select EventMenu()
      EndSelect

    Case #PB_Event_Gadget
      Select EventGadget()
      EndSelect
  EndSelect
  ProcedureReturn #True
EndProcedure

