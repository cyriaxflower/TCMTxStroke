Global Window_3

Global Editor_7, Editor_8, Editor_9, Button_8, Button_9

Enumeration FormFont
  #Font_Window_3_0
EndEnumeration

LoadFont(#Font_Window_3_0,"標楷體", 18)


Procedure OpenWindow_3(x = 0, y = 0, width = 1000, height = 590)
  Window_3 = OpenWindow(#PB_Any, x, y, width, height, "綜合建議", #PB_Window_SystemMenu | #PB_Window_MinimizeGadget | #PB_Window_MaximizeGadget | #PB_Window_SizeGadget | #PB_Window_WindowCentered | #PB_Window_SystemMenu | #PB_Window_MinimizeGadget | #PB_Window_MaximizeGadget | #PB_Window_SizeGadget | #PB_Window_WindowCentered)
  SetWindowColor(Window_3, RGB(202,202,202))
  Editor_7 = EditorGadget(#PB_Any, 10, 10, 980, 160)
  SetGadgetFont(Editor_7, FontID(#Font_Window_3_0))
  Editor_8 = EditorGadget(#PB_Any, 10, 180, 980, 160)
  SetGadgetFont(Editor_8, FontID(#Font_Window_3_0))
  Editor_9 = EditorGadget(#PB_Any, 10, 350, 980, 160)
  SetGadgetFont(Editor_9, FontID(#Font_Window_3_0))
  Button_8 = ButtonGadget(#PB_Any, 180, 530, 290, 50, "將建議存檔後結束本程式")
  SetGadgetFont(Button_8, FontID(#Font_Window_3_0))
  Button_9 = ButtonGadget(#PB_Any, 520, 530, 340, 50, "不存檔, 直接結束本程式")
  SetGadgetFont(Button_9, FontID(#Font_Window_3_0))
EndProcedure

Procedure Window_3_Events(event)
  Select event
    Case #PB_Event_CloseWindow
      ProcedureReturn #False

    Case #PB_Event_Menu
      Select EventMenu()
      EndSelect

    Case #PB_Event_Gadget
      Select EventGadget()
      EndSelect
  EndSelect
  ProcedureReturn #True
EndProcedure

